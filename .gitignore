### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml

### dotfiles ###
# Secrets / AMD-internal config must never enter this public repo.
.config/claude-code/
home/.config/claude-code/
# Machine/private overlays live in the private repo or in $HOME only.
*.private
# Local Claude Code settings and install backups.
.claude/settings.local.json
.dotfiles-backup/
# NFS lock artifacts.
.nfs*